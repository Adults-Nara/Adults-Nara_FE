{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@repo/config/*": ["packages/config/*"],
      "@repo/ui/*": ["packages/ui/*"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "exclude": ["node_modules", "dist", ".next"]
}
