{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@repo/configs/*": ["packages/configs/*"],
      "@repo/ui/*": ["packages/ui/*"],
      "@repo/ui": ["packages/ui/src/index.ts"],
      "@repo/ui/icons": ["packages/ui/src/icons"],
      "@repo/ui/icons/*": ["packages/ui/src/icons/*"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "exclude": ["node_modules", "dist", ".next"]
}
